{
  "annotations": { "list": [] },
  "title": "Plugin Gateway Overview",
  "uid": "plugin-gateway-overview",
  "schemaVersion": 27,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Gateway Requests (rate)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(plugin_gateway_requests_total[5m])) by (slug)", "legendFormat": "{{slug}}" }],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Gateway Duration (p95)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(plugin_gateway_duration_seconds_bucket[5m])) by (le, slug))", "legendFormat": "{{slug}} p95" }],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "id": 3,
      "title": "Circuit Breaker State",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "plugin_gateway_breaker_state", "legendFormat": "{{slug}}" }],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 }
    },
    {
      "id": 4,
      "title": "Error Rate by Plugin",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(plugin_gateway_requests_total{status=~\"5..\"}[5m])) by (slug) / sum(rate(plugin_gateway_requests_total[5m])) by (slug)", "legendFormat": "{{slug}} error rate" }],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 }
    }
  ]
}

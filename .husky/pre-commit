#!/bin/sh

echo "Checking core OSS workspace builds..."

# Build shared package first because the public apps depend on it.
pnpm --filter shared build
if [ $? -ne 0 ]; then
  echo "Shared package build failed."
  exit 1
fi

# Verify the public API can compile before commit.
pnpm --filter api build
if [ $? -ne 0 ]; then
  echo "API build failed."
  exit 1
fi

echo "Pre-commit build verification passed."

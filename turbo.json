{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "concurrency": "12",
  "globalDependencies": [
    ".env",
    ".env.production",
    ".env.example"
  ],
  "globalEnv": [
    "NODE_ENV",
    "LOG_LEVEL",
    "DATABASE_URL",
    "REDIS_URL",
    "API_PORT",
    "API_HOST",
    "CORS_ORIGIN",
    "CORS_ENABLED",
    "JWT_SECRET",
    "JWT_EXPIRES_IN",
    "API_SERVICE_URL",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_ADMIN_URL",
    "NEXT_PUBLIC_SUPER_ADMIN_URL",
    "NEXT_PUBLIC_SHOP_URL",
    "STRIPE_SECRET_KEY",
    "STRIPE_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "RESEND_API_KEY",
    "RESEND_WEBHOOK_SECRET"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*",
        "!**/*.tsbuildinfo"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "!.next/standalone/**",
        "!.next/trace",
        "!.next/**/*.map",
        "dist/**"
      ],
      "outputLogs": "new-only",
      "persistent": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ]
    },
    "type-check": {
      "dependsOn": [
        "^type-check"
      ]
    },
    "test": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*",
        "!**/*.tsbuildinfo"
      ]
    },
    "clean": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "db:reset": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    }
  }
}

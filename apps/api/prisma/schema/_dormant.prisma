// ============================================================
// DORMANT: INSTALLED THEME
// Superseded by file-system-based theme registry
// ============================================================
// DORMANT since 2026-07: no code references, do not use
model InstalledTheme {
  id String @id @default(cuid())

  slug   String
  target String

  name        String
  version     String
  author      String?
  description String?

  source      String @default("local-zip")
  installPath String

  isActive Boolean @default(false)

  config Json?

  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([slug, target])
  @@index([target])
  @@index([isActive])
  @@map("installed_themes")
  @@schema("public")
}


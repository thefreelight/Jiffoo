// commerce.prisma — Store, Category, Product, Variant, Translation,
//                   Discount*, Order, OrderItem, Cart, CartItem, Recommendation*

// ============================================================
// STORE
// ============================================================
model Store {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  domain           String?  @unique
  status           String   @default("active")
  currency         String   @default("USD")
  defaultLocale    String   @default("en")
  supportedLocales Json?
  settings         Json?
  logo             String?
  themeConfig      Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users     User[]
  products  Product[]
  orders    Order[]
  errorLogs ErrorLog[]

  @@index([status])
  @@map("stores")
  @@schema("public")
}

// ============================================================
// CATEGORY
// ============================================================
model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  parentId    String?
  level       Int      @default(1)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // SEO fields
  metaTitle       String?
  metaDescription String?
  canonicalUrl    String?
  structuredData  Json?

  // Relations
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  @@index([parentId])
  @@map("categories")
  @@schema("public")
}

// ============================================================
// PRODUCT
// ============================================================
model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true)
  storeId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Product type system
  productType String @default("physical")
  typeData    Json?

  // Physical product fields
  weight           Float?
  length           Float?
  width            Float?
  height           Float?
  requiresShipping Boolean @default(true)
  shippingClass    String?

  // SEO fields
  metaTitle       String?
  metaDescription String?
  canonicalUrl    String?
  structuredData  Json?

  // Relations
  store                 Store                  @relation(fields: [storeId], references: [id])
  categoryId            String?
  category              Category?              @relation(fields: [categoryId], references: [id])
  orderItems            OrderItem[]
  cartItems             CartItem[]
  inventoryReservations InventoryReservation[]
  translations          ProductTranslation[]
  variants              ProductVariant[]
  discountProducts      DiscountProduct[]
  affinitiesAsA         ProductAffinity[]      @relation("ProductAffinityA")
  affinitiesAsB         ProductAffinity[]      @relation("ProductAffinityB")

  @@index([categoryId])
  @@index([productType])
  @@index([storeId])
  @@map("products")
  @@schema("public")
}

// ============================================================
// PRODUCT VARIANT
// ============================================================
model ProductVariant {
  id         String   @id @default(cuid())
  productId  String
  name       String
  attributes Json?
  salePrice  Decimal  @default(0) @db.Decimal(18, 2)
  costPrice  Decimal? @db.Decimal(18, 2)
  // Legacy compatibility field. Authoritative stock is warehouse_inventories.available.
  baseStock  Int      @default(0)
  skuCode    String?
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  product               Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems            OrderItem[]
  cartItems             CartItem[]
  inventoryReservations InventoryReservation[]
  warehouseInventories  WarehouseInventory[]
  inventoryAdjustments  InventoryAdjustment[]
  inventoryTransfers    InventoryTransfer[]
  stockAlerts           StockAlert[]

  @@index([productId])
  @@index([skuCode])
  @@map("product_variants")
  @@schema("public")
}

// ============================================================
// PRODUCT TRANSLATION
// ============================================================
model ProductTranslation {
  id          String   @id @default(cuid())
  productId   String
  locale      String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
  @@index([productId])
  @@index([locale])
  @@map("product_translations")
  @@schema("public")
}

// ============================================================
// DISCOUNT
// ============================================================
model Discount {
  id          String    @id @default(cuid())
  code        String    @unique
  type        String
  value       Decimal   @db.Decimal(10, 2)
  minAmount   Decimal?  @db.Decimal(18, 2)
  maxUses     Int?
  usedCount   Int       @default(0)
  startDate   DateTime?
  endDate     DateTime?
  isActive    Boolean   @default(true)
  stackable   Boolean   @default(false)
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products       DiscountProduct[]
  customerGroups DiscountCustomerGroup[]
  usages         DiscountUsage[]

  @@index([isActive])
  @@index([code])
  @@map("discounts")
  @@schema("public")
}

model DiscountProduct {
  id         String   @id @default(cuid())
  discountId String
  productId  String
  createdAt  DateTime @default(now())

  discount Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([discountId, productId])
  @@index([productId])
  @@map("discount_products")
  @@schema("public")
}

model DiscountCustomerGroup {
  id            String   @id @default(cuid())
  discountId    String
  customerGroup String
  createdAt     DateTime @default(now())

  discount Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)

  @@unique([discountId, customerGroup])
  @@map("discount_customer_groups")
  @@schema("public")
}

model DiscountUsage {
  id             String   @id @default(cuid())
  discountId     String
  userId         String
  orderId        String
  discountAmount Decimal  @db.Decimal(18, 2)
  createdAt      DateTime @default(now())

  discount Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([discountId, orderId])
  @@index([userId])
  @@index([orderId])
  @@map("discount_usages")
  @@schema("public")
}

// ============================================================
// ORDER
// ============================================================
model Order {
  id      String      @id @default(cuid())
  userId  String
  storeId String
  status  OrderStatus @default(PENDING)

  // Payment status fields
  paymentStatus        OrderPaymentStatus @default(PENDING)
  expiresAt            DateTime?
  lastPaymentAttemptAt DateTime?
  paymentAttempts      Int                @default(0)
  lastPaymentMethod    String?
  cancelReason         String?
  cancelledAt          DateTime?

  // Pricing fields
  subtotalAmount Decimal @db.Decimal(18, 2)
  discountAmount Decimal @default(0) @db.Decimal(18, 2)
  taxAmount      Decimal @default(0) @db.Decimal(18, 2)
  totalAmount    Decimal @db.Decimal(18, 2)
  currency       String  @default("USD")

  customerEmail String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  user                  User                   @relation(fields: [userId], references: [id])
  store                 Store                  @relation(fields: [storeId], references: [id])
  shippingAddress       OrderShippingAddress?
  items                 OrderItem[]
  payments              Payment[]
  refunds               Refund[]
  paymentLedgers        PaymentLedger[]
  refundLedgers         RefundLedger[]
  discountUsages        DiscountUsage[]
  externalOrderLinks    ExternalOrderLink[]
  inventoryReservations InventoryReservation[]
  shipments             Shipment[]
  statusHistory         OrderStatusHistory[]

  @@index([status])
  @@index([paymentStatus])
  @@index([expiresAt])
  @@index([userId])
  @@index([storeId])
  @@map("orders")
  @@schema("public")
}

// ============================================================
// ORDER ITEM
// ============================================================
model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  variantId String
  quantity  Int
  unitPrice Decimal @db.Decimal(18, 2)
  currency  String  @default("USD")

  // Shipping address (per item)
  shippingFirstName    String?
  shippingLastName     String?
  shippingPhone        String?
  shippingEmail        String?
  shippingAddressLine1 String?
  shippingAddressLine2 String?
  shippingCity         String?
  shippingState        String?
  shippingCountry      String?
  shippingPostalCode   String?

  // Fulfillment
  fulfillmentStatus OrderItemFulfillmentStatus @default(pending)
  fulfillmentData   Json?

  // Relations
  order              Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product            Product             @relation(fields: [productId], references: [id])
  variant            ProductVariant      @relation(fields: [variantId], references: [id])
  externalOrderLinks ExternalOrderLink[]
  shipments          ShipmentItem[]

  @@index([orderId])
  @@index([variantId])
  @@index([fulfillmentStatus])
  @@index([shippingCountry])
  @@map("order_items")
  @@schema("public")
}

// ============================================================
// CART
// ============================================================
model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@index([userId])
  @@index([status])
  @@map("carts")
  @@schema("public")
}

// ============================================================
// CART ITEM
// ============================================================
model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  productId String
  quantity  Int
  price     Decimal @db.Decimal(18, 2)
  variantId String

  // Shipping address draft (per item, nullable until user fills in)
  shippingFirstName    String?
  shippingLastName     String?
  shippingPhone        String?
  shippingEmail        String?
  shippingAddressLine1 String?
  shippingAddressLine2 String?
  shippingCity         String?
  shippingState        String?
  shippingCountry      String?
  shippingPostalCode   String?

  fulfillmentData Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product        @relation(fields: [productId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([cartId])
  @@index([productId])
  @@index([variantId])
  @@map("cart_items")
  @@schema("public")
}

// ============================================================
// RECOMMENDATION SYSTEM
// ============================================================
model RecommendationInteraction {
  id                 String   @id @default(cuid())
  userId             String?
  productId          String
  sessionId          String
  recommendationType String
  sourceProductId    String?
  sourceContext      String?
  action             String
  algorithmVariant   String?
  testGroupId        String?
  metadata           Json?
  createdAt          DateTime @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([productId])
  @@map("recommendation_interactions")
  @@schema("public")
}

model RecommendationConfig {
  id                 String   @id @default(cuid())
  name               String
  recommendationType String
  algorithm          String
  isActive           Boolean  @default(true)
  trafficPercentage  Float    @default(100.0)
  priority           Int      @default(0)
  parameters         Json?
  metricsJson        Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("recommendation_configs")
  @@schema("public")
}

// extension.prisma — PluginInstall, PluginInstallation, PluginServiceToken,
//                    WebhookSubscription, WebhookDeliveryLog, WebhookDeadLetter,
//                    PluginThemeExtension

// ============================================================
// PLUGIN INSTALL (package metadata)
// ============================================================
model PluginInstall {
  id   String @id @default(cuid())
  slug String @unique

  name        String
  version     String
  author      String?
  authorUrl   String?
  description String?
  category    String?

  runtimeType     String  @default("internal-fastify")
  entryModule     String?
  externalBaseUrl String?

  source      String  @default("local-zip")
  installPath String?

  zipHash      String?
  manifestJson Json?

  permissions Json?

  deletedAt DateTime?

  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  installations PluginInstallation[]

  @@index([category])
  @@index([runtimeType])
  @@index([zipHash])
  @@index([deletedAt])
  @@map("plugin_installs")
  @@schema("public")
}

// ============================================================
// PLUGIN INSTALLATION (instance)
// ============================================================
model PluginInstallation {
  id          String @id @default(uuid())
  pluginSlug  String
  instanceKey String

  enabled Boolean @default(true)

  configJson Json?

  grantedPermissions Json?

  deletedAt DateTime?

  lifecycleWarning String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plugin               PluginInstall          @relation(fields: [pluginSlug], references: [slug], onDelete: Cascade)
  serviceTokens        PluginServiceToken[]
  webhookSubscriptions WebhookSubscription[]
  themeExtensions      PluginThemeExtension[]

  @@unique([pluginSlug, instanceKey])
  @@index([pluginSlug])
  @@index([enabled])
  @@index([deletedAt])
  @@map("plugin_installations")
  @@schema("public")
}

// ============================================================
// PLUGIN SERVICE TOKEN
// ============================================================
model PluginServiceToken {
  id             String    @id @default(cuid())
  installationId String
  tokenHash      String
  status         String    @default("active")
  expiresAt      DateTime
  issuedAt       DateTime  @default(now())
  lastUsedAt     DateTime?

  installation PluginInstallation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  @@index([installationId])
  @@index([tokenHash])
  @@index([status])
  @@map("plugin_service_tokens")
  @@schema("public")
}

// ============================================================
// WEBHOOK SUBSCRIPTION
// ============================================================
model WebhookSubscription {
  id             String   @id @default(cuid())
  installationId String
  eventType      String
  deliveryMode   String   @default("internal")
  endpointUrl    String?
  secret         String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  installation PluginInstallation   @relation(fields: [installationId], references: [id], onDelete: Cascade)
  deliveryLogs WebhookDeliveryLog[]
  deadLetters  WebhookDeadLetter[]

  @@index([installationId])
  @@index([eventType])
  @@index([active])
  @@map("webhook_subscriptions")
  @@schema("public")
}

// ============================================================
// WEBHOOK DELIVERY LOG
// ============================================================
model WebhookDeliveryLog {
  id             String   @id @default(cuid())
  subscriptionId String
  eventId        String
  attempt        Int      @default(1)
  status         String
  responseCode   Int?
  responseBody   String?
  errorMessage   String?
  deliveredAt    DateTime @default(now())
  latencyMs      Int?

  subscription WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([eventId])
  @@index([status])
  @@map("webhook_delivery_logs")
  @@schema("public")
}

// ============================================================
// WEBHOOK DEAD LETTER
// ============================================================
model WebhookDeadLetter {
  id             String    @id @default(cuid())
  eventId        String
  subscriptionId String
  eventType      String
  payload        Json
  lastError      String?
  retryCount     Int       @default(0)
  createdAt      DateTime  @default(now())
  replayedAt     DateTime?

  subscription WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([eventId])
  @@index([eventType])
  @@map("webhook_dead_letters")
  @@schema("public")
}

// ============================================================
// PLUGIN THEME EXTENSION
// ============================================================
model PluginThemeExtension {
  id             String   @id @default(cuid())
  installationId String
  kind           String
  extensionId    String
  name           String
  schema         Json?
  dataEndpoint   String?
  targetPosition String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  installation PluginInstallation @relation(fields: [installationId], references: [id], onDelete: Cascade)

  @@unique([installationId, extensionId])
  @@index([installationId])
  @@index([kind])
  @@index([active])
  @@map("plugin_theme_extensions")
  @@schema("public")
}

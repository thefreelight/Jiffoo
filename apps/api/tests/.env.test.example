# apps/api tests - Minimal .env.test example
# Copy to `apps/api/tests/.env.test` and adjust DB only.

NODE_ENV=test
LOG_LEVEL=error
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5432/jiffoo_test?schema=public
REDIS_URL=redis://localhost:6379/15

API_HOST=127.0.0.1
API_PORT=3001
CORS_ENABLED=false
CORS_CREDENTIALS=false
CORS_ORIGIN=http://localhost:3000

JWT_SECRET=test-secret-key-for-testing
JWT_EXPIRES_IN=7d

API_SERVICE_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_SHOP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3002

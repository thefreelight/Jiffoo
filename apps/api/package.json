{
  "name": "api",
  "version": "1.0.2",
  "description": "Jiffoo Mall API Service",
  "main": "dist/server.js",
  "_moduleAliases": {
    "@jiffoo/shared": "../../packages/shared/dist/shared/src",
    "@shared/security": "../../packages/shared/dist/shared/src/security",
    "@shared/observability": "../../packages/shared/dist/shared/src/observability",
    "shared/logger": "../../packages/shared/dist/shared/src/logger"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc && tsc-alias -p tsconfig.json && node scripts/repair-dist-runtime-imports.mjs",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/core",
    "test:integration": "vitest run tests/routes",
    "test:contract": "vitest run tests/contract",
    "test:quality": "npm run test:unit && npm run test:integration && npm run test:contract",
    "test:e2e": "playwright test -c tests/e2e/playwright.admin.config.ts",
    "test:e2e:admin": "playwright test -c tests/e2e/playwright.admin.config.ts",
    "test:e2e:shop": "playwright test -c tests/e2e/playwright.shop.config.ts",
    "test:smoke": "vitest run tests/routes/system.test.ts tests/routes/auth.test.ts tests/routes/products.test.ts",
    "test:gate:fast": "npm run lint && npm run type-check && npm run test:smoke && npm run test:unit && npm run test:contract",
    "test:gate:pr": "npm run test:gate:fast && npm run test:integration",
    "test:gate:full": "npm run test:gate:pr && npm run test:coverage",
    "test:ci": "npm run test:gate:full",
    "clean": "rm -rf dist",
    "db:generate": "dotenv -e .env -- prisma generate",
    "db:migrate": "dotenv -e .env -- prisma migrate dev",
    "db:migrate-deploy": "prisma migrate deploy",
    "db:sync-local": "prisma db push --accept-data-loss",
    "db:studio": "dotenv -e .env -- prisma studio",
    "db:reset": "dotenv -e .env -- prisma migrate reset",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:production": "prisma db seed",
    "db:mode:test": "dotenv -e tests/.env.test -- node scripts/run-test-migrate.js",
    "build:official-artifacts": "tsx scripts/build-official-artifacts.ts",
    "docker:build": "docker build -t api:latest .",
    "export:openapi": "tsx scripts/export-openapi.ts"
  },
  "keywords": [
    "fastify",
    "typescript",
    "mall",
    "ecommerce",
    "api"
  ],
  "author": "Jiffoo Team",
  "license": "MIT",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^22.9.0",
    "@types/unzip-stream": "^0.3.4",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "@vitest/coverage-v8": "^4.0.15",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9.36.0",
    "tsc-alias": "^1.8.8",
    "typescript": "^5.8.3",
    "vitest": "4.0.15"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.966.0",
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^10.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^9.2.1",
    "@fastify/static": "^8.2.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@paypal/paypal-server-sdk": "^1.1.0",
    "@prisma/client": "^6.18.0",
    "@scalar/fastify-api-reference": "^1.44.20",
    "@sendgrid/mail": "^8.1.4",
    "@sentry/node": "^10.39.0",
    "@types/uuid": "^9.0.7",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "archiver": "^7.0.1",
    "axios": "^1.11.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.5.0",
    "extract-zip": "^2.0.1",
    "fastify": "^5.6.1",
    "fastify-raw-body": "^5.0.0",
    "google-auth-library": "^10.4.0",
    "https-proxy-agent": "^8.0.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "module-alias": "^2.2.3",
    "multer": "^2.0.0",
    "prisma": "^6.18.0",
    "redis": "^5.1.1",
    "resend": "^6.1.2",
    "shared": "workspace:*",
    "sharp": "^0.34.3",
    "stripe": "^18.2.1",
    "svix": "^1.77.0",
    "tsx": "^4.6.0",
    "twilio": "^5.6.1",
    "unzip-stream": "^0.3.4",
    "uuid": "^9.0.1",
    "web-push": "^3.6.7",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.22.4"
  }
}

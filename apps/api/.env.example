# Core API (Open Source) - Port 3001

# Environment
NODE_ENV=development
LOG_LEVEL=debug

# Server
API_PORT=3001
API_HOST=0.0.0.0

# Database (public schema)
DATABASE_URL=postgresql://core_api:core_api_dev@localhost:5432/jiffoo_mall?schema=public
REDIS_URL=redis://localhost:6379

# Rate Limiting
# SECURITY: Controls behavior when Redis (rate limiter backend) becomes unavailable
# - true (RECOMMENDED): Uses in-memory fallback to continue enforcing rate limits
#   Protects against DoS attacks even when Redis fails. Memory usage bounded by LRU eviction.
# - false: Allows all requests through when Redis fails (fail-open mode)
#   NOT RECOMMENDED for production - exposes system to DoS attacks during Redis outages
RATE_LIMITER_FAIL_CLOSED=true

# JWT
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=7d

# CORS
CORS_ENABLED=true
CORS_CREDENTIALS=true
CORS_ORIGIN=http://localhost:3002,http://localhost:3003

# URLs
API_SERVICE_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_ADMIN_URL=http://localhost:3002
NEXT_PUBLIC_SHOP_URL=http://localhost:3003

# Extensions directory (relative to project root or absolute path)
# Points to the repository root's extensions/ directory
EXTENSIONS_PATH=../../extensions

# Push Notifications (VAPID Keys)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-public-key-here
VAPID_PRIVATE_KEY=your-private-key-here

# Catalog Import (internal service token)
CATALOG_IMPORT_TOKEN=local-dev-catalog-import-token

# Official Marketplace
# In development, point this to local platform-api to simulate the market
# In production, leave unset to use the default: https://market.jiffoo.com/api/v1
MARKET_API_URL=http://localhost:3011/api
OFFICIAL_EXTENSIONS_BOOTSTRAP_MODE=launch-ready

# Admin bootstrap/demo credential display
# bootstrap = show seeded admin credentials until the password is changed
# demo = always show demo credentials
# normal = never show demo credentials
AUTH_BOOTSTRAP_MODE=bootstrap
AUTH_BOOTSTRAP_ADMIN_EMAIL=admin@jiffoo.com
AUTH_BOOTSTRAP_ADMIN_PASSWORD=admin123

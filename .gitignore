# Dependencies
node_modules/
**/node_modules
.pnpm-store/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test directories and reports
unified-release-report-*.md

# Build outputs
dist/
build/
.next/
.turbo/
.docusaurus/

# TypeScript build artifacts
*.tsbuildinfo
next-env.d.ts
**/next-env.d.ts

# fumadocs auto-generated source directory
apps/docs/.source/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
apps/*/.env
apps/*/.env.local
apps/*/.env.development.local
apps/*/.env.test.local
apps/*/.env.production.local

# Generated i18n messages
packages/i18n/messages/

# Keep example files
!.env.example
!apps/*/.env.example

# Database
*.db
*.sqlite

# Logs
logs
*.log

# MCP Configuration (contains sensitive tokens)
.mcp/

# Runtime data
pids
*.pid
*.seed
*.pid.lock
.local/

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# Extensions (runtime installation directory)
# 运行时安装的插件和主题默认不进 git；官方 package-managed 插件源码除外
extensions/plugins/*
extensions/themes/*
!extensions/plugins/.gitkeep
!extensions/themes/.gitkeep
!extensions/plugins/stripe/
!extensions/plugins/stripe/**
!extensions/plugins/i18n/
!extensions/plugins/i18n/**
!extensions/plugins/odoo/
!extensions/plugins/odoo/**
extensions/plugins/*/.installed.json
extensions/plugins/*/checksums.json
extensions/plugins/*/node_modules/
extensions/plugins/*/dist/

# Theme/Plugin zip artifacts (build products, should not be committed)
*.zip
packages/shop-themes/*.zip

# API extensions runtime directory (should use EXTENSIONS_PATH env var)
apps/api/extensions/

# Playwright
playwright-report/
test-results/
playwright/.cache/
apps/api/tests/e2e/.auth/
apps/api/tests/e2e/playwright-report/
e2e/visual/baselines/*.png

# nyc test coverage
.nyc_output

# IDE
.vscode/
.idea/
*.swp
*.swo

# Claude Code local settings (may contain sensitive paths or personal preferences)
.claude/settings.json
.claude/settings.local.json

# OS
.DS_Store
Thumbs.db

# Prisma
prisma/migrations/
imagerAI/

# Auto Claude data directory
.auto-claude/

# Auto Claude generated files
.auto-claude-security.json
.auto-claude-status
.claude_settings.json
.worktrees/
.tools/
.security-key
logs/security/

# Theme package scratch files
packages/shop-themes/*/diff_*.txt

generator client {
  provider      = "prisma-client-js"
  output        = "../node_modules/.prisma/i18n-client"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("I18N_DATABASE_URL")
}

// ============================================================================
// Content Translations
// ============================================================================
// Stores translations for any core entity (product, category, page, etc.)
// Written by the plugin, synced to Redis for core API to read.

model ContentTranslation {
  id           String   @id @default(cuid())
  entityType   String                          // "product", "category", "page", "banner"
  entityId     String                          // ID in core system
  locale       String                          // "zh-Hant", "fr", "ja"
  field        String                          // "name", "description", "metaTitle"
  value        String   @db.Text
  sourceDigest String?                         // SHA-256 of source content (stale detection)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([entityType, entityId, locale, field])
  @@index([entityType, entityId, locale])
  @@index([entityType, locale])
  @@map("content_translations")
}

// ============================================================================
// UI Text Translations
// ============================================================================
// Stores UI string translations/overrides for themes and apps.
// Theme built-in locale files provide defaults; these entries override them.

model UITranslation {
  id        String   @id @default(cuid())
  locale    String                             // "zh-Hant", "fr", "ja"
  namespace String                             // "common", "shop", "merchant"
  key       String                             // "nav.home", "cart.title", "product.addToCart"
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([locale, namespace, key])
  @@index([locale, namespace])
  @@map("ui_translations")
}

// ============================================================================
// Managed Languages
// ============================================================================
// Tracks which languages are available, their display names, and fallback chain.

model ManagedLanguage {
  id           String   @id @default(cuid())
  locale       String   @unique               // "en", "zh-Hant", "fr"
  name         String                          // "English", "French"
  nativeName   String                          // "English", "Francais"
  isDefault    Boolean  @default(false)
  isEnabled    Boolean  @default(true)
  fallbackTo   String?                         // Fallback locale code (e.g. "en")
  direction    String   @default("ltr")        // "ltr" or "rtl"
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("managed_languages")
}

// ============================================================================
// Translation Jobs (for batch / auto-translate tracking)
// ============================================================================

model TranslationJob {
  id           String   @id @default(cuid())
  targetLocale String
  entityType   String?                         // null = UI translations
  provider     String   @default("manual")     // "manual", "deepl", "gpt"
  status       String   @default("pending")    // "pending", "running", "completed", "failed"
  totalKeys    Int      @default(0)
  doneKeys     Int      @default(0)
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@map("translation_jobs")
}

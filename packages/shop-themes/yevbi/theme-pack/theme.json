{
  "schemaVersion": 1,
  "slug": "yevbi",
  "name": "Yevbi",
  "version": "1.0.0",
  "target": "shop",
  "description": "Official downloadable storefront theme package with a travel-focused design language.",
  "author": "Jiffoo",
  "entry": {
    "tokensCSS": "tokens.css",
    "templatesDir": "templates",
    "assetsDir": "assets",
    "settingsSchema": "schemas/settings.schema.json"
  },
  "compatibility": {
    "minCoreVersion": "0.2.0"
  },
  "defaultConfig": {
    "colors": {
      "primary": "#ffffff",
      "secondary": "#0a0a0a",
      "background": "#000000",
      "foreground": "#ffffff",
      "muted": "#eaeaea",
      "border": "#1a1a1a",
      "accent": "#111111"
    },
    "typography": {
      "fontFamily": "system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
      "headingFamily": "system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
      "fontSize": "16px",
      "lineHeight": "1.5"
    },
    "layout": {
      "radius": "2px",
      "containerWidth": "1200px",
      "spacing": "1rem",
      "headerHeight": "72px"
    },
    "features": {
      "showWishlist": false,
      "showRatings": false,
      "enableQuickView": false
    }
  },
  "x-jiffoo-renderer-mode": "embedded",
  "x-jiffoo-renderer-slug": "yevbi",
  "category": "travel",
  "tags": [
    "travel",
    "modern",
    "responsive"
  ]
}

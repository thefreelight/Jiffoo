{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "../../..",
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": "../../..",
    "paths": {
      "shared": ["./packages/shared"],
      "shared/*": ["./packages/shared/*"],
      "@shop-themes/default/*": ["./packages/shop-themes/default/*"],
      "@shop-themes/digital-vault/*": ["./packages/shop-themes/digital-vault/*"],
      "@jiffoo/ui": ["./packages/ui/src/index.ts"],
      "@jiffoo/ui/*": ["./packages/ui/src/*"]
    }
  },
  "include": ["src/**/*"],
  "references": [
    { "path": "../../shared" }
  ]
}

{
  "type": "object",
  "title": "NavToAI Settings",
  "properties": {
    "brand": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "title": "Brand Name"
        },
        "primaryColor": {
          "type": "string",
          "title": "Primary Color"
        },
        "secondaryColor": {
          "type": "string",
          "title": "Secondary Color"
        },
        "fontFamily": {
          "type": "string",
          "title": "Font Family"
        }
      }
    },
    "layout": {
      "type": "object",
      "properties": {
        "maxWidth": {
          "type": "string",
          "title": "Max Width"
        }
      }
    },
    "i18n": {
      "type": "object",
      "properties": {
        "locale": {
          "type": "string",
          "title": "Default Locale",
          "enum": [
            "en",
            "zh-Hans",
            "zh-Hant"
          ]
        }
      }
    },
    "site": {
      "type": "object",
      "properties": {
        "eyebrow": {
          "type": "string",
          "title": "Hero Eyebrow"
        },
        "headline": {
          "type": "string",
          "title": "Hero Headline"
        },
        "subheadline": {
          "type": "string",
          "title": "Hero Subheadline"
        },
        "primaryCtaLabel": {
          "type": "string",
          "title": "Primary CTA Label"
        },
        "primaryCtaHref": {
          "type": "string",
          "title": "Primary CTA Link"
        },
        "secondaryCtaLabel": {
          "type": "string",
          "title": "Secondary CTA Label"
        },
        "secondaryCtaHref": {
          "type": "string",
          "title": "Secondary CTA Link"
        },
        "supportEmail": {
          "type": "string",
          "title": "Support Email"
        },
        "docsHref": {
          "type": "string",
          "title": "Documentation Link"
        },
        "demoHref": {
          "type": "string",
          "title": "Directory Link"
        }
      }
    }
  }

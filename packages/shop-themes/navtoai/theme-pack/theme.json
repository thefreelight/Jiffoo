{
  "schemaVersion": 1,
  "slug": "navtoai",
  "name": "NavToAI",
  "version": "0.2.2",
  "target": "shop",
  "description": "Premium multilingual AI navigation storefront theme with curated discovery, ranking blocks, and paid project submission flows.",
  "author": "Jiffoo",
  "thumbnail": "assets/thumbnail.svg",
  "category": "ai",
  "entry": {
    "tokensCSS": "tokens.css",
    "templatesDir": "templates",
    "assetsDir": "assets",
    "settingsSchema": "schemas/settings.schema.json"
  },
  "compatibility": {
    "minCoreVersion": "0.2.0"
  },
  "x-jiffoo-renderer-mode": "embedded",
  "x-jiffoo-renderer-slug": "navtoai",
  "defaultConfig": {
    "brand": {
      "name": "NavtoAI",
      "primaryColor": "#6a6cff",
      "secondaryColor": "#7bc9ff",
      "fontFamily": "\"Plus Jakarta Sans\", \"SF Pro Display\", \"PingFang SC\", \"Hiragino Sans GB\", \"Microsoft YaHei\", sans-serif"
    },
    "layout": {
      "headerSticky": true,
      "showFooterLinks": true,
      "maxWidth": "1440px"
    },
    "features": {
      "showWishlist": true,
      "showRatings": true,
      "enableQuickView": false
    },
    "site": {
      "archetype": "product-site",
      "primaryCtaHref": "/products",
      "secondaryCtaHref": "/help",
      "docsHref": "/help",
      "demoHref": "/products",
      "supportEmail": "hello@navto.ai"
    }
  },
  "tags": [
    "ai",
    "directory",
    "workflow",
    "navigation",
    "tooling",
    "light-theme",
    "multilingual",
    "paid-submission"
  ]
}

{
  "schemaVersion": 1,
  "slug": "esim-mall",
  "name": "eSIM Mall",
  "version": "1.0.0",
  "target": "shop",
  "description": "Official downloadable storefront theme package for digital eSIM sales.",
  "author": "Jiffoo",
  "entry": {
    "tokensCSS": "tokens.css",
    "templatesDir": "templates",
    "assetsDir": "assets",
    "settingsSchema": "schemas/settings.schema.json"
  },
  "compatibility": {
    "minCoreVersion": "0.2.0"
  },
  "defaultConfig": {
    "colors": {
      "primary": "#2563eb",
      "secondary": "#06b6d4",
      "background": "#ffffff",
      "foreground": "#1f2937",
      "muted": "#4b5563",
      "border": "#e5e7eb",
      "accent": "#06b6d4"
    },
    "typography": {
      "fontFamily": "system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
      "headingFamily": "system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
      "fontSize": "16px",
      "lineHeight": "1.5"
    },
    "layout": {
      "radius": "0.75rem",
      "containerWidth": "1280px",
      "spacing": "1rem",
      "headerHeight": "72px"
    },
    "features": {
      "showWishlist": false,
      "showRatings": false,
      "enableQuickView": false
    }
  },
  "x-jiffoo-renderer-mode": "embedded",
  "x-jiffoo-renderer-slug": "esim-mall",
  "category": "esim",
  "tags": [
    "esim",
    "travel",
    "connectivity",
    "modern"
  ]
}

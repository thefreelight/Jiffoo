{
  "schemaVersion": 1,
  "slug": "digital-vault",
  "name": "Digital Vault",
  "version": "1.0.0",
  "target": "shop",
  "description": "A storefront theme for virtual goods, instant codes, account credentials, and downloadable assets.",
  "author": "Jiffoo",
  "entry": {
    "tokensCSS": "tokens.css"
  },
  "compatibility": {
    "minCoreVersion": "0.2.0"
  },
  "defaultConfig": {
    "colors": {
      "primary": "#3563f6",
      "secondary": "#0f2942",
      "background": "#f7f9fd",
      "foreground": "#15223a",
      "muted": "#ebf0fa",
      "border": "#dfe6f3",
      "accent": "#f4c971"
    },
    "typography": {
      "fontFamily": "Inter, system-ui, sans-serif",
      "headingFamily": "Inter, system-ui, sans-serif",
      "fontSize": "16px",
      "lineHeight": "1.5"
    },
    "layout": {
      "radius": "18px",
      "containerWidth": "1280px",
      "spacing": "1rem",
      "headerHeight": "76px"
    }
  },
  "x-jiffoo-renderer-mode": "embedded",
  "x-jiffoo-renderer-slug": "digital-vault",
  "category": "digital-goods",
  "tags": ["digital", "gift-cards", "codes", "downloads", "credentials"]
}

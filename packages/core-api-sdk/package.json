{
  "name": "@jiffoo/core-api-sdk",
  "version": "0.2.0",
  "description": "Public HTTP SDK for Jiffoo Mall Core API (Shop + Admin)",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src/openapi-types.ts"
  ],
  "scripts": {
    "generate:openapi-types": "openapi-typescript ../../apps/api/openapi.json -o src/openapi-types.ts",
    "build": "pnpm run build:esm && pnpm run build:cjs && pnpm run build:types",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:types": "tsc -p tsconfig.types.json",
    "dev": "tsc -p tsconfig.esm.json --watch",
    "clean": "rimraf dist"
  },
  "keywords": [
    "jiffoo",
    "core-api",
    "sdk",
    "openapi",
    "shop",
    "admin"
  ],
  "author": "Jiffoo Team",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "openapi-fetch": "^0.15.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "openapi-typescript": "^7.6.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3"
  }
}